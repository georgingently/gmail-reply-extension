{
  "manifest_version": 3,
  "name": "Gmail Reply Extension",
  "version": "1.0.0",
  "description": "AI-powered Gmail replies using Groq.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://mail.google.com/*"],
  "action": {
    "default_popup": "dist/src/popup/index.html"
  },
  "background": {
    "service_worker": "dist/src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["dist/src/content/index.js"]
    }
  ]
}
